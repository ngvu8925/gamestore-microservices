# Copy file này thành .env và điền giá trị thực
# cp .env.example .env

# Database credentials
DB_URL=jdbc:sqlserver://your-db-host:1433;databaseName=microservices;encrypt=true;trustServerCertificate=true;loginTimeout=30
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Secret (phải dài ít nhất 32 ký tự)
JWT_SECRET=your_very_long_jwt_secret_key_at_least_32_chars
